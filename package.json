{
	"name": "langx",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright install && playwright test",
		"test:smoke": "playwright test e2e/smoke.e2e.ts",
		"test:ui": "playwright test e2e/ui.e2e.ts",
		"test:demos": "playwright test e2e/demos.e2e.ts",
		"test:rigorous": "playwright test e2e/rigorous.e2e.ts",
		"preflight": "node --experimental-strip-types scripts/preflight.ts"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.4",
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.59.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.2",
		"@types/diff": "^7.0.2",
		"@types/dompurify": "^3.0.5",
		"@types/node": "^24",
		"@vitest/browser-playwright": "^4.1.3",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.4.0",
		"mdsvex": "^0.12.7",
		"playwright": "^1.59.1",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.2",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"vite": "^8.0.7",
		"vitest": "^4.1.3",
		"vitest-browser-svelte": "^2.1.0"
	},
	"dependencies": {
		"@huggingface/transformers": "^4.2.0",
		"@langchain/anthropic": "^1.4.0",
		"@langchain/core": "^1.1.48",
		"@langchain/groq": "^1.2.1",
		"@langchain/langgraph": "^1.3.2",
		"@langchain/openai": "^1.4.7",
		"@langchain/textsplitters": "^1.0.1",
		"@observablehq/plot": "^0.6.17",
		"dexie": "^4.4.3",
		"diff": "^9.0.0",
		"dompurify": "^3.4.7",
		"js-tiktoken": "^1.0.21",
		"marked": "^18.0.4",
		"mermaid": "^11.15.0",
		"shiki": "^4.1.0",
		"zod": "^4.4.3"
	}
}
